<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Open Cart Test Suite" verbose="4" thread-count="1" parallel="tests">
	<listeners>
		<listener
			class-name="com.qa.Myapp.listeners.ExtentReportListener" />
		<listener
			class-name="com.qa.Myapp.listeners.TestAllureListener" />
			<listener
			class-name="com.qa.Myapp.listeners.AnnotationTransformer" />

	</listeners>
	
	<test name="Open Cart Login Page ">
		<classes>
			<class name="com.qa.Myapp.tests.loginPageTest" />
		</classes>
	</test>
	
	<test name="Open Cart Account Page">
		
		<classes>
			<class name="com.qa.Myapp.tests.AccountsPageTest" />
		</classes>
	</test>
	
	
	<test name="Open Cart NegativeLogin Test ">
		
		<classes>
			<class name="com.qa.Myapp.tests.LoginNegativeTest" />
		</classes>
	</test>

	
</suite>